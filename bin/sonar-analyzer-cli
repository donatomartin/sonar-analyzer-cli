#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
JAR_PATH="${PROJECT_DIR}/sonar-cli-app/target/sonar-analyzer-cli.jar"

if [[ ! -f "${JAR_PATH}" ]]; then
  echo "Missing ${JAR_PATH}. Run: mvn package" >&2
  exit 2
fi

exec java -jar "${JAR_PATH}" "$@"
